# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For Vercel: Add this to your project environment variables.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links and notifications.
APP_URL="https://your-app-domain.com"

# Database Configuration (Postgres)
# Required for persisting demo requests, contact forms, and site data.
SQL_HOST="your-db-host"
SQL_USER="your-db-user"
SQL_PASSWORD="your-db-password"
SQL_DB_NAME="your-db-name"

# WhatsApp Notification Configuration (CallMeBot)
# Get your free API key at: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE="+919678377275"
WHATSAPP_API_KEY="YOUR_CALLMEBOT_API_KEY"
